@{
    ViewData["Title"] = "Student";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div ng-controller="StudentCtrl">
    <div class="container mt-4">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h2 class="mb-0">{{ form.id === 0 ? "Add" : "Edit" }} Student</h2>
            </div>
            <div class="card-body">
                <form ng-submit="save()">
                    <input type="hidden" ng-model="form.id" />

                    <div class="mb-3">
                        <label class="form-label">Name:</label>
                        <input class="form-control" ng-model="form.name" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Address:</label>
                        <input type="text" class="form-control" ng-model="form.address" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Age:</label>
                        <input type="number" class="form-control" ng-model="form.age" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Phone:</label>
                        <input type="text" class="form-control" ng-model="form.phone" required />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <button type="button" class="btn btn-secondary" ng-click="resetForm()">Cancel</button>
                        <button type="button" class="btn btn-danger" ng-click="remove(form.id)" ng-if="form.id > 0">Delete</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header bg-primary text-white">
                <h2 class="mb-0">Student List</h2>
            </div>
            <div class="card-body p-0">

                <!-- 🔍 Filter input -->
                <div class="p-3">
                    <input type="text" class="form-control" placeholder="Search by name, age, address, or phone..." ng-model="searchQuery" />
                </div>

                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Age</th>
                            <th>Address</th>
                            <th>Phone</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr ng-repeat="student in students | filter:searchQuery" ng-click="selectStudent(student)" style="cursor: pointer;">
                            <td>{{ student.id }}</td>
                            <td>{{ student.name }}</td>
                            <td>{{ student.age }}</td>
                            <td>{{ student.address }}</td>
                            <td>{{ student.phone }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    var app = angular.module('studentApp', []);

    app.controller('StudentCtrl', function($scope, $http) {
        $scope.students = [];
        $scope.searchQuery = "";
        $scope.form = {
            id: 0,
            name: "",
            age: 0,
            address: "",
            phone: ""
        };

        $scope.load = function() {
            $http.get('/Student/GetAll').then(function(res) {
                $scope.students = res.data;
            });
        };

        $scope.save = function() {
            if ($scope.form.id > 0) {
                $http.post('/Student/Edit', $scope.form).then(function() {
                    $scope.load();
                    $scope.resetForm();
                });
            } else {
                $http.post('/Student/Create', $scope.form).then(function() {
                    $scope.load();
                    $scope.resetForm();
                });
            }
        };

        $scope.selectStudent = function(student) {
            $scope.form = angular.copy(student);
        };

        $scope.remove = function(id) {
            if (confirm("Are you sure?")) {
                $http.post('/Student/Delete?id=' + id).then(function() {
                    $scope.load();
                    $scope.resetForm();
                });
            }
        };

        $scope.resetForm = function() {
            $scope.form = {
                id: 0,
                name: "",
                age: 0,
                address: "",
                phone: ""
            };
        };

        // Initial load
        $scope.load();
    });
</script>
