@{
    ViewData["Title"] = "Student";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="student-app">
    <div class="container mt-4">
        <!-- Form -->
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h2 class="mb-0" data-bind="text: (form.id() === 0 ? 'Add' : 'Edit') + ' Student'"></h2>
            </div>
            <div class="card-body">
                <form data-bind="submit: save">
                    <input type="hidden" data-bind="value: form.id" />

                    <div class="mb-3">
                        <label class="form-label">Name:</label>
                        <input class="form-control" data-bind="value: form.name" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Address:</label>
                        <input type="text" class="form-control" data-bind="value: form.address" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Age:</label>
                        <input type="number" class="form-control" data-bind="value: form.age" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Phone:</label>
                        <input type="text" class="form-control" data-bind="value: form.phone" required />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <button type="button" class="btn btn-secondary" data-bind="click: resetForm">Cancel</button>
                        <button type="button" class="btn btn-danger" data-bind="click: function() { remove(form.id()) }, visible: form.id() > 0">Delete</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- List -->
        <div class="card mt-4">
            <div class="card-header bg-primary text-white">
                <h2 class="mb-0">Student List</h2>
            </div>
            <div class="card-body p-0">
                <!-- Filter -->
                <div class="p-3">
                     <input type="text" class="form-control" placeholder="Search by name, age, address, or phone..." data-bind="textInput: searchQuery" />
                </div>

                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Age</th>
                            <th>Address</th>
                            <th>Phone</th>
                        </tr>
                    </thead>
                    <tbody data-bind="foreach: filteredStudents">
                        <tr data-bind="click: $parent.selectStudent" style="cursor: pointer;">
                            <td data-bind="text: id"></td>
                            <td data-bind="text: name"></td>
                            <td data-bind="text: age"></td>
                            <td data-bind="text: address"></td>
                            <td data-bind="text: phone"></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    function StudentViewModel() {
        var self = this;

        self.students = ko.observableArray([]);
        self.searchQuery = ko.observable("");

        self.form = {
            id: ko.observable(0),
            name: ko.observable(""),
            age: ko.observable(0),
            address: ko.observable(""),
            phone: ko.observable("")
        };

        // Filtered Students
        self.filteredStudents = ko.computed(function() {
            var query = self.searchQuery().toLowerCase();
            if (!query) {
                return self.students();
            } else {
                return ko.utils.arrayFilter(self.students(), function(student) {
                    return (student.name && student.name.toLowerCase().indexOf(query) !== -1) ||
                           (student.address && student.address.toLowerCase().indexOf(query) !== -1) ||
                           (String(student.age) && String(student.age).indexOf(query) !== -1) ||
                           (student.phone && student.phone.indexOf(query) !== -1);
                });
            }
        });

        self.load = function() {
            axios.get('/Student/GetAll').then(res => {
                self.students(res.data);
            });
        };

        self.save = function() {
            var data = ko.toJS(self.form);
            // Ensure types are correct if needed (e.g. age number)
            data.age = parseInt(data.age) || 0;
            
            if (data.id > 0) {
                axios.post('/Student/Edit', data).then(() => {
                    self.load();
                    self.resetForm();
                });
            } else {
                axios.post('/Student/Create', data).then(() => {
                    self.load();
                    self.resetForm();
                });
            }
        };

        self.selectStudent = function(student) {
            self.form.id(student.id);
            self.form.name(student.name);
            self.form.age(student.age);
            self.form.address(student.address);
            self.form.phone(student.phone);
        };

        self.remove = function(id) {
            if (confirm("Are you sure?")) {
                axios.post('/Student/Delete?id=' + id).then(() => {
                     self.load();
                     self.resetForm();
                });
            }
        };

        self.resetForm = function() {
            self.form.id(0);
            self.form.name("");
            self.form.age(0);
            self.form.address("");
            self.form.phone("");
        };

        // Initial load
        self.load();
    }

    ko.applyBindings(new StudentViewModel(), document.getElementById("student-app"));
</script>
