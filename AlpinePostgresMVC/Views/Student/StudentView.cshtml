@{
    ViewData["Title"] = "Student";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div x-data="studentApp()" x-init="load()">
    <div class="container mt-4">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h2 class="mb-0" x-text="form.id === 0 ? 'Add Student' : 'Edit Student'"></h2>
            </div>
            <div class="card-body">
                <form x-on:submit.prevent="save">
                    <input type="hidden" x-model="form.id" />

                    <div class="mb-3">
                        <label class="form-label">Name:</label>
                        <input class="form-control" x-model="form.name" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Address:</label>
                        <input type="text" class="form-control" x-model="form.address" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Age:</label>
                        <input type="number" class="form-control" x-model.number="form.age" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Phone:</label>
                        <input type="text" class="form-control" x-model="form.phone" required />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <button type="button" class="btn btn-secondary" x-on:click="resetForm">Cancel</button>
                        <button type="button" class="btn btn-danger" x-on:click="remove(form.id)" x-show="form.id > 0">Delete</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header bg-primary text-white">
                <h2 class="mb-0">Student List</h2>
            </div>
            <div class="card-body p-0">

                <!-- 🔍 Filter input -->
                <div class="p-3">
                    <input type="text" class="form-control" placeholder="Search by name, age, address, or phone..." x-model="searchQuery" />
                </div>

                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Age</th>
                            <th>Address</th>
                            <th>Phone</th>
                        </tr>
                    </thead>
                    <tbody>
                        <template x-for="student in filteredStudents" :key="student.id">
                            <tr x-on:click="selectStudent(student)" style="cursor: pointer;">
                                <td x-text="student.id"></td>
                                <td x-text="student.name"></td>
                                <td x-text="student.age"></td>
                                <td x-text="student.address"></td>
                                <td x-text="student.phone"></td>
                            </tr>
                        </template>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    function studentApp() {
        return {
            students: [],
            searchQuery: "",
            form: {
                id: 0,
                name: "",
                age: 0,
                address: "",
                phone: ""
            },
            get filteredStudents() {
                if (this.searchQuery === "") {
                    return this.students;
                }
                const lowerSearch = this.searchQuery.toLowerCase();
                return this.students.filter(s => 
                    s.name.toLowerCase().includes(lowerSearch) ||
                    s.address.toLowerCase().includes(lowerSearch) ||
                    s.phone.toLowerCase().includes(lowerSearch) ||
                    s.age.toString().includes(lowerSearch)
                );
            },
            load() {
                axios.get('/Student/GetAll').then(res => {
                    this.students = res.data;
                });
            },
            save() {
                if (this.form.id > 0) {
                    axios.post('/Student/Edit', this.form).then(() => {
                        this.load();
                        this.resetForm();
                    });
                } else {
                    axios.post('/Student/Create', this.form).then(() => {
                        this.load();
                        this.resetForm();
                    });
                }
            },
            selectStudent(student) {
                // Clone the object to avoid binding directly to the list item
                this.form = { ...student };
            },
            remove(id) {
                if (confirm("Are you sure?")) {
                    axios.post('/Student/Delete?id=' + id).then(() => {
                        this.load();
                        this.resetForm();
                    });
                }
            },
            resetForm() {
                this.form = {
                    id: 0,
                    name: "",
                    age: 0,
                    address: "",
                    phone: ""
                };
            }
        }
    }
</script>
