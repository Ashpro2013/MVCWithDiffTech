@model HtmxMVCApp.Models.StudentPageViewModel

@if (Model.Part == "list")
{
    Layout = null;
    <table class="table table-hover mb-0">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Age</th>
                <th>Address</th>
                <th>Phone</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Students == null || !Model.Students.Any())
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-3">No students found.</td>
                </tr>
            }
            else
            {
                @foreach (var student in Model.Students)
                {
                    <tr hx-get="/Student/GetForm?id=@student.Id" 
                        hx-target="#student-form-container" 
                        hx-swap="innerHTML" 
                        style="cursor: pointer;">
                        <td>@student.Id</td>
                        <td>@student.Name</td>
                        <td>@student.Age</td>
                        <td>@student.Address</td>
                        <td>@student.Phone</td>
                    </tr>
                }
            }
        </tbody>
    </table>
}
else if (Model.Part == "form")
{
    Layout = null;
    <div class="card-header bg-primary text-white">
        <h2 class="mb-0">@(Model.FormStudent.Id == 0 ? "Add Student" : "Edit Student")</h2>
    </div>
    <div class="card-body">
        <form hx-post="/Student/Save" 
              hx-target="#student-form-container" 
              hx-swap="innerHTML">
            
            <input type="hidden" name="Id" value="@Model.FormStudent.Id" />

            <div class="mb-3">
                <label class="form-label">Name:</label>
                <input type="text" class="form-control" name="Name" value="@Model.FormStudent.Name" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Address:</label>
                <input type="text" class="form-control" name="Address" value="@Model.FormStudent.Address" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Age:</label>
                <input type="number" class="form-control" name="Age" value="@(Model.FormStudent.Id == 0 ? "" : Model.FormStudent.Age)" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Phone:</label>
                <input type="text" class="form-control" name="Phone" value="@Model.FormStudent.Phone" required />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save</button>
                <button type="button" 
                        class="btn btn-secondary" 
                        hx-get="/Student/GetForm" 
                        hx-target="#student-form-container" 
                        hx-swap="innerHTML">Cancel</button>
                @if (Model.FormStudent.Id > 0)
                {
                    <button type="button" 
                            class="btn btn-danger" 
                            hx-post="/Student/Delete?id=@Model.FormStudent.Id" 
                            hx-confirm="Are you sure?" 
                            hx-target="#student-form-container" 
                            hx-swap="innerHTML">Delete</button>
                }
            </div>
        </form>
    </div>
}
else
{
    ViewData["Title"] = "Student";
    Layout = "~/Views/Shared/_Layout.cshtml";

    <div class="container mt-4">
        <!-- Form Card -->
        <div class="card">
            <div id="student-form-container" 
                 hx-get="/Student/GetForm" 
                 hx-trigger="load" 
                 hx-swap="innerHTML">
                <div class="card-body text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading form...</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- List Card -->
        <div class="card mt-4">
            <div class="card-header bg-primary text-white">
                <h2 class="mb-0">Student List</h2>
            </div>
            <div class="card-body p-0">
                <!-- 🔍 Filter input -->
                <div class="p-3">
                    <input type="text" 
                           id="searchQuery"
                           name="searchQuery" 
                           class="form-control" 
                           placeholder="Search by name, age, address, or phone..." 
                           hx-get="/Student/GetList"
                           hx-trigger="keyup changed delay:300ms, search"
                           hx-target="#student-list-container"
                           hx-swap="innerHTML" />
                </div>

                <!-- Table Container -->
                <div id="student-list-container" 
                     hx-get="/Student/GetList" 
                     hx-trigger="load, studentChanged from:body" 
                     hx-include="#searchQuery"
                     hx-swap="innerHTML">
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading list...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
